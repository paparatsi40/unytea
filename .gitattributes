# Auto-detect text vs binary, normalize text to LF
* text=auto eol=lf

# Explicit text files (defensive)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Explicit binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
